<?xml version="1.0" encoding="utf-8"?>
<!-- B-2 fix: Android 12+ (API 31+) 的细粒度备份规则
     分别控制 cloud-backup(云备份)与 device-transfer(设备转移)的可备份域。
     当前策略:只备份 Room 数据库,排除临时文件与缓存。
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="word_master_db" />
        <exclude domain="sharedpref" path="device.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="word_master_db" />
        <exclude domain="sharedpref" path="device.xml" />
    </device-transfer>
</data-extraction-rules>